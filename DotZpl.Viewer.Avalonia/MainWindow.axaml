<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:DotZpl.Viewer.Shared.ViewModels"
        xmlns:zpl="clr-namespace:DotZpl.Controls;assembly=DotZpl"
        x:Class="DotZpl.Viewer.Avalonia.MainWindow"
        x:DataType="vm:MainViewModel"
        Title="DotZpl Viewer" Width="1200" Height="800">

    <Grid Margin="6">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240" MinWidth="140" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="380" MinWidth="240" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" MinWidth="240" />
        </Grid.ColumnDefinitions>

        <!-- Label browser -->
        <TabControl Grid.Column="0">
            <TabItem Header="Tests">
                <ListBox ItemsSource="{Binding TestLabels}" SelectedItem="{Binding SelectedTestLabel}">
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="vm:LabelItem">
                            <TextBlock Text="{Binding Display}" />
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </TabItem>
            <TabItem Header="Examples">
                <ListBox ItemsSource="{Binding ExampleLabels}" SelectedItem="{Binding SelectedExampleLabel}">
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="vm:LabelItem">
                            <TextBlock Text="{Binding Display}" />
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </TabItem>
        </TabControl>

        <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                      Background="#80808080" />

        <!-- ZPL editor -->
        <DockPanel Grid.Column="2">
            <TextBox Text="{Binding ZplText, Mode=TwoWay}"
                     AcceptsReturn="True" AcceptsTab="True" FontFamily="Consolas"
                     VerticalContentAlignment="Top" />
        </DockPanel>

        <GridSplitter Grid.Column="3" Width="5" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                      Background="#80808080" />

        <!-- Preview: label format / actions toolbar + transform toolbar + render + diagnostics -->
        <DockPanel Grid.Column="4">
            <Border DockPanel.Dock="Top" BorderBrush="#80808080" BorderThickness="0,0,0,1" Padding="6">
                <WrapPanel>
                    <TextBlock Text="Format:" VerticalAlignment="Center" Margin="0,0,6,0" />
                    <ComboBox ItemsSource="{Binding LabelFormats}" SelectedItem="{Binding SelectedFormat}"
                              Width="160" Margin="0,0,14,0">
                        <ComboBox.ItemTemplate>
                            <DataTemplate DataType="vm:LabelFormat">
                                <TextBlock Text="{Binding Display}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <TextBox Text="{Binding LabelWidth}" Width="50" />
                    <TextBlock Text="mm" VerticalAlignment="Center" Margin="3,0,2,0" />
                    <TextBlock Text="{Binding LabelWidthInch, StringFormat=({0} in)}" VerticalAlignment="Center" Margin="0,0,12,0" />

                    <TextBox Text="{Binding LabelHeight}" Width="50" />
                    <TextBlock Text="mm" VerticalAlignment="Center" Margin="3,0,2,0" />
                    <TextBlock Text="{Binding LabelHeightInch, StringFormat=({0} in)}" VerticalAlignment="Center" Margin="0,0,12,0" />

                    <TextBox Text="{Binding PrintDensityDpmm}" Width="40" />
                    <TextBlock Text="dpmm" VerticalAlignment="Center" Margin="3,0,2,0" />
                    <TextBlock Text="{Binding Dpi, StringFormat=({0} dpi)}" VerticalAlignment="Center" Margin="0,0,14,0" />

                    <Button Content="Render" Command="{Binding RenderCommand}" Padding="12,3" Margin="0,0,6,0" />
                    <Button Content="Save PNG" Command="{Binding SavePngCommand}" Padding="12,3" Margin="0,0,6,0" />
                    <Button Content="Save ZPL" Command="{Binding SaveZplCommand}" Padding="12,3" Margin="0,0,14,0" />

                    <Border Width="1" Background="#80808080" Margin="0,2,14,2" />
                    <TextBlock Text="Printer:" VerticalAlignment="Center" Margin="0,0,6,0" />
                    <TextBox Text="{Binding PrinterAddress}" Width="130"
                             VerticalAlignment="Center" ToolTip.Tip="Printer IP or host (optionally host:port; default 9100)" Margin="0,0,6,0" />
                    <Button Content="Print" Command="{Binding PrintCommand}" Padding="12,3" Margin="0,0,10,0" />
                    <TextBlock Text="{Binding PrintStatus}" VerticalAlignment="Center" Opacity="0.8" />
                </WrapPanel>
            </Border>

            <Border DockPanel.Dock="Top" BorderBrush="#80808080" BorderThickness="0,0,0,1" Padding="6">
                <WrapPanel>
                    <TextBlock Text="Rotation:" VerticalAlignment="Center" Margin="0,0,4,0" />
                    <ComboBox ItemsSource="{Binding RotationAngles}" SelectedItem="{Binding RotationAngle}"
                              Width="80" Margin="0,0,14,0" />

                    <TextBlock Text="Pan X:" VerticalAlignment="Center" Margin="0,0,4,0" />
                    <Slider Minimum="-1000" Maximum="1000" Value="{Binding OffsetX}" Width="130"
                            VerticalAlignment="Center" Margin="0,0,14,0" />

                    <TextBlock Text="Pan Y:" VerticalAlignment="Center" Margin="0,0,4,0" />
                    <Slider Minimum="-1000" Maximum="1000" Value="{Binding OffsetY}" Width="130"
                            VerticalAlignment="Center" Margin="0,0,14,0" />

                    <TextBlock Text="Zoom:" VerticalAlignment="Center" Margin="0,0,4,0" />
                    <Slider Minimum="0.1" Maximum="20" Value="{Binding Zoom}" Width="130"
                            VerticalAlignment="Center" Margin="0,0,4,0" />
                    <TextBlock Text="{Binding Zoom, StringFormat='{}{0:P0}'}" VerticalAlignment="Center" Width="44" Margin="0,0,14,0" />

                    <Button Content="Reset" Command="{Binding ResetTransformCommand}" Padding="10,2" />
                </WrapPanel>
            </Border>

            <StackPanel DockPanel.Dock="Bottom">
                <Border Background="#FFF3CD" BorderBrush="#FFE69C" BorderThickness="1" Padding="8" Margin="0,6,0,0"
                        TextElement.Foreground="#664D03"
                        IsVisible="{Binding HasUnknownCommands}">
                    <StackPanel>
                        <TextBlock Text="Non-supported commands" FontWeight="Bold" />
                        <ItemsControl ItemsSource="{Binding UnknownCommands}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="x:String">
                                    <TextBlock Text="{Binding}" FontFamily="Consolas" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <Border Background="#F8D7DA" BorderBrush="#F5C2C7" BorderThickness="1" Padding="8" Margin="0,6,0,0"
                        TextElement.Foreground="#842029"
                        IsVisible="{Binding HasRenderError}">
                    <StackPanel>
                        <TextBlock Text="Render error" FontWeight="Bold" />
                        <TextBlock Text="{Binding RenderError}" TextWrapping="Wrap" FontFamily="Consolas" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <Border BorderBrush="#CCCCCC" BorderThickness="1" Background="#EFEFEF" Margin="0,6,0,0" ClipToBounds="True">
                <zpl:ZplLabelView Zpl="{Binding PreviewZpl}"
                                  LabelWidth="{Binding PreviewWidth}"
                                  LabelHeight="{Binding PreviewHeight}"
                                  PrintDensityDpmm="{Binding PreviewDpmm}"
                                  RotationAngle="{Binding RotationAngle}"
                                  OffsetX="{Binding OffsetX, Mode=TwoWay}"
                                  OffsetY="{Binding OffsetY, Mode=TwoWay}"
                                  Zoom="{Binding Zoom, Mode=TwoWay}"
                                  Stretch="Uniform" Margin="10" />
            </Border>
        </DockPanel>
    </Grid>
</Window>
